# TMP112 temperature sensor configuration options (HARDWARIO variant)

#
# Copyright (c) 2016 Firmwave
# Copyright (c) 2026 HARDWARIO a.s.
#
# SPDX-License-Identifier: Apache-2.0
#

menuconfig HIO_TMP112
	bool "TMP112 Temperature Sensor (HARDWARIO variant)"
	default y
	depends on DT_HAS_HARDWARIO_TMP112_ENABLED
	select I2C
	help
	  Enable the HARDWARIO driver for Texas Instruments TMP112 High-Accuracy
	  Digital Temperature Sensors.

	  This variant adds shutdown / one-shot operation: when the
	  conversion-rate device-tree property is set to 0, the sensor stays in
	  shutdown and a one-shot conversion is triggered on each sample_fetch.

	  The TMP102 is compatible with the TMP112 but is less accurate and has
	  been successfully tested with this driver.

if HIO_TMP112

config HIO_TMP112_FULL_SCALE_RUNTIME
	bool "Allow to set extended mode at runtime"
	default y
	help
	  When set extended mode can be selected using sensor_attr_set
	  with SENSOR_ATTR_FULL_SCALE and value to set either 128 or 150.

config HIO_TMP112_SAMPLING_FREQUENCY_RUNTIME
	bool "Allow to set conversion rate at runtime"
	default y
	help
	  When set conversion rate can be set at runtime using sensor_attr_set
	  with SENSOR_ATTR_SAMPLING_FREQUENCY. Setting the rate to 0 Hz at
	  runtime puts the sensor into shutdown / one-shot mode.

endif # HIO_TMP112
